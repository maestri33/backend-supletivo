# Contrato de env do backend Django+Ninja.
#
# Cópia este arquivo para `.env` (gitignored) e preenche com os valores
# do teu ambiente. O `.env.example` é versionado e serve de documentação;
# o `.env` NUNCA é commitado (e nunca deve conter chaves reais).
#
# Convenções:
# - dev  → DEBUG=True, CORS_ALLOW_ALL_ORIGINS=True, ALLOWED_HOSTS=*
# - prod → DEBUG=False, CORS_ALLOW_ALL_ORIGINS=False, lista explícita de origins

# ─── Django core ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-prod-50-chars-random
DEBUG=False
ALLOWED_HOSTS=backend.v7m.live,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=core.settings

# ─── CORS / hosts ─────────────────────────────────────────────────────────
# dev: CORS_ALLOW_ALL_ORIGINS=True; prod: False + lista explícita.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://app.supletivo.net.br,https://app.v7m.org

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/dbname
# dev pode ser sqlite:///db.sqlite3

# ─── Mídia / uploads ──────────────────────────────────────────────────────
MEDIA_LAN_BASE=
MAX_UPLOAD_MB=10

# ─── URLs externas (deep links para o app cliente) ────────────────────────
EXTERNAL_URL=https://app.supletivo.net.br
FRONTEND_URL=https://app.supletivo.net.br
ENROLLMENT_RESUME_PATH=/matricula
INSTITUTION_LOGIN_URL=https://cbi.sistemasiga.net/login/

# ─── JWT (Ninja + django-ninja-jwt, RS256) ────────────────────────────────
JWT_ALGORITHM=RS256
JWT_ISSUER=v7m
JWT_AUDIENCE=v7m-apps
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=1440
# As chaves pública/privada RSA vivem em `keys/` (gitignored) e são
# auto-geradas no primeiro boot se faltarem. Não exportar o PEM em env.

# ─── OTP (passwordless) ───────────────────────────────────────────────────
OTP_ACTIVE=True
OTP_TTL_S=600
OTP_NUM_DIGITS=6
OTP_MAX_ATTEMPTS=3
# Rate-limit por IP fica no reverse proxy (CONVENTION §5), não no app.
OTP_RATELIMIT_WINDOW_S=60
OTP_RATELIMIT_HOURLY_MAX=10
OTP_FOOTER=V7M · código de acesso

# ─── Treinamento / comissão ───────────────────────────────────────────────
TRAINING_PASS_SCORE=70
COMMISSION_DIRECT=50
COMMISSION_COORDINATOR=20
COMMISSION_BONUS_FLAT=0
COMMISSION_BONUS_THRESHOLD=5
# Fechamento semanal (0=seg..4=sex, hora em America/Sao_Paulo)
COMMISSION_CLOSING_WEEKDAY=4
COMMISSION_CLOSING_HOUR=18

# ROLE_RULES — JSON array. Cada item: {from_role, to_role, mode, requires_role?, blocking?}.
# Default está em core/settings.py; só exportar se quiser override (ex.: desabilitar o
# overlay de training, mudar thresholds). Victor 2026-06-16: training virou ROLE OVERLAY
# (add+blocking), coordenador virou aditivo sobre promotor.
ROLE_RULES=[{"from_role": null, "to_role": "lead", "mode": "add"}]

# ─── Hub / staff default ──────────────────────────────────────────────────
HUB_BRANDS=wyden,estacio,standard
DEFAULT_HUB_BRAND=wyden
DEFAULT_STAFF_NAME=
DEFAULT_STAFF_CPF=
DEFAULT_STAFF_PHONE=
DEFAULT_STAFF_PIX=
DEFAULT_STAFF_PASSWORD=

# ─── Enrollment (cliente final) ───────────────────────────────────────────
ENROLLMENT_PRICE_PIX=0
ENROLLMENT_PRICE_CARD_CENTS=0
ENROLLMENT_PRICE_PROMOTER_PIX=0
ENROLLMENT_PRICE_PROMOTER_CARD_CENTS=0
ENROLLMENT_DESCRIPTION=Matrícula EAD · V7M

# ─── Biometria (InsightFace, CPU) ────────────────────────────────────────
BIOMETRIC_ENABLED=True
BIOMETRIC_MODEL_NAME=buffalo_l
BIOMETRIC_MODEL_ROOT=/var/lib/v7m/models/insightface
BIOMETRIC_MATCH_THRESHOLD=0.35
BIOMETRIC_REVIEW_THRESHOLD=0.28
BIOMETRIC_LIVENESS_PROVIDER=local

# ─── Analysis (poll de jobs async) ───────────────────────────────────────
ANALYSIS_TTL_SECONDS=300
ANALYSIS_POLL_MS=2500

# ─── IA providers (genéricos) ────────────────────────────────────────────
# Lista os provedores habilitados. Para cada, exportar `IA_<NAME>_BASE_URL`
# e `IA_<NAME>_API_KEY`. Cadeia de fallback = ordem de tentativa.
IA_PROVIDERS=minimax,gemini,deepseek,openai
IA_FALLBACK_CHAIN=minimax,gemini
IA_DEFAULT_TEMPERATURE=0.3
IA_MAX_TOKENS=0
IA_TIMEOUT=60.0

# MiniMax (TTS + Vision)
IA_MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_API_KEY=
MINIMAX_VISION_MODEL=
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_FEMALE=
MINIMAX_VOICE_MALE=

# Gemini (Vision + Image)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_VISION_MODEL=gemini-3-flash-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
IA_GEMINI_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_VOICE_FEMALE=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_MALE=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_SPEED=1.0
ELEVENLABS_STYLE=0.0
ELEVENLABS_SPEAKER_BOOST=True

# Google Vision (fallback OCR)
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_BASE_URL=https://vision.googleapis.com
GOOGLE_VISION_SERVICE_ACCOUNT_JSON=

# ─── Integrações financeiras ──────────────────────────────────────────────
# Asaas (PIX in/out)
ASAAS_BASE_URL=https://api.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_WEBHOOK_NAME=dmz-asaas-managed
ASAAS_CHARGE_DUE_DAYS=3

# InfinitePay (PIX in)
INFINITEPAY_BASE_URL=https://api.infinitepay.io
INFINITEPAY_HANDLE=
INFINITEPAY_REDIRECT_URL=
INFINITEPAY_HTTP_TIMEOUT=10.0

# ─── CEP / CPF utilities ──────────────────────────────────────────────────
VIACEP_BASE_URL=https://viacep.com.br
VIACEP_TIMEOUT_SECONDS=5.0
CPFHUB_BASE_URL=https://api.cpfhub.io
CPFHUB_API_KEY=
CPFHUB_TIMEOUT=5.0

# ─── Comunicação ─────────────────────────────────────────────────────────
# WhatsApp (via gateway; cada integration tem seu próprio provider)
WHATSAPP_API_BASE_URL=
WHATSAPP_GLOBAL_API_KEY=
WHATSAPP_INSTANCE_NAME=

# Email (SMTP)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_TIMEOUT=30
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=V7M

# ─── Async (django-q, broker no DB) ──────────────────────────────────────
Q_WORKERS=2
URL_VERIFY_NONCE_TTL=600