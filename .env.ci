DJANGO_SETTINGS_MODULE=core.settings
SECRET_KEY=ci_test_key_not_real
DEBUG=true
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=true
DATABASE_URL=sqlite:///db.sqlite3
# TEST_MODE=0 no CI: o `manage.py check` roda no runner backend-v7m (= servidor de deploy), e a
# trava anti-prod (settings.py) recusa TEST_MODE=1 num host fora de TEST_MODE_ALLOWED_HOSTS. Os
# testes NÃO perdem o modo de teste — o conftest seta settings.TEST_MODE=True em runtime. Não
# enfraquece a trava (ela segue barrando TEST_MODE=1 em prod).
TEST_MODE=0
EXTERNAL_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
LANDING_BASE_URL=http://localhost:3000
BIOMETRIC_MODEL_ROOT=/opt/test/models/insightface
WHATSAPP_WEBHOOK_SECRET=ci_test_secret
WHATSAPP_API_BASE_URL=http://127.0.0.1:9999
WHATSAPP_GLOBAL_API_KEY=ci_test_key
CPFHUB_API_KEY=ci_test_key
IA_PROVIDERS=fake
IA_FAKE_BASE_URL=http://127.0.0.1:9999
IA_FAKE_API_KEY=ci_test_key
IA_FALLBACK_CHAIN=fake:fake-model
IA_GEMINI_BASE_URL=http://127.0.0.1:9999
IA_GEMINI_API_KEY=ci_test_key
MINIMAX_BASE_URL=http://127.0.0.1:9999
MINIMAX_API_KEY=ci_test_key
ELEVENLABS_BASE_URL=http://127.0.0.1:9999
ELEVENLABS_API_KEY=ci_test_key
INFINITEPAY_HANDLE=ci_test_handle
MAIL_SMTP_HOST=localhost
MAIL_SMTP_USER=test@ci.test
MAIL_SMTP_PASSWORD=ci_test_password
DEFAULT_FROM_EMAIL=ci@test.test
DEFAULT_STAFF_NAME=CI Test
DEFAULT_STAFF_CPF=11144477735
